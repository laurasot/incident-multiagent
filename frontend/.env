# Host Agent Configuration
#
# Run the setup script to automatically populate these values:
#   chmod +x ./setup-env.sh
#   ./setup-env.sh
#
# Or manually set them below:

# AWS Region where the host agent is deployed
VITE_AWS_REGION=us-west-2

# Host Agent ARN (fetched from SSM parameter: /hostagent/agentcore/runtime-id)
# Format: arn:aws:bedrock-agentcore:{region}:{account_id}:runtime/{runtime_id}
VITE_AGENT_ARN=arn:aws:bedrock-agentcore:us-west-2:305529619736:runtime/supervisor_agent_dev-jlYin2ETi4
VITE_COGNITO_USER_POOL_ID=us-west-2_YToVWCS5m
